<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Нигора, у меня вопрос 🐼</title>
<link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --pink: #FF8FAB;
    --pink-light: #FFD6E0;
    --peach: #FFCBA4;
    --cream: #FFF5F7;
    --brown: #5C3D2E;
    --purple: #C77DFF;
    --purple-light: #E8D5FF;
    --green: #74C69D;
    --text: #3D2C35;
    --shadow: 0 8px 32px rgba(255,143,171,0.18);
  }

  body {
    font-family: 'Nunito', sans-serif;
    background: var(--cream);
    color: var(--text);
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 20px;
    background-image: 
      radial-gradient(circle at 10% 20%, #FFD6E033 0%, transparent 50%),
      radial-gradient(circle at 90% 80%, #E8D5FF33 0%, transparent 50%),
      radial-gradient(circle at 50% 50%, #FFCBA422 0%, transparent 70%);
  }

  .screen {
    display: none;
    width: 100%;
    max-width: 420px;
    animation: fadeIn 0.5s ease;
  }
  .screen.active { display: block; }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .card {
    background: white;
    border-radius: 28px;
    padding: 32px 28px;
    box-shadow: var(--shadow);
    text-align: center;
  }

  .panda {
    font-size: 80px;
    line-height: 1;
    margin-bottom: 12px;
    display: block;
    animation: bounce 2s infinite;
  }

  @keyframes bounce {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-8px); }
  }

  @keyframes shake {
    0%, 100% { transform: translateX(0) rotate(0); }
    20% { transform: translateX(-6px) rotate(-3deg); }
    40% { transform: translateX(6px) rotate(3deg); }
    60% { transform: translateX(-4px) rotate(-2deg); }
    80% { transform: translateX(4px) rotate(2deg); }
  }

  .panda.sad { animation: shake 0.6s ease; }

  h1 {
    font-size: 26px;
    font-weight: 900;
    color: var(--text);
    line-height: 1.3;
    margin-bottom: 8px;
  }

  .subtitle {
    font-size: 15px;
    color: #9B7B8A;
    margin-bottom: 28px;
    line-height: 1.5;
  }

  .btn {
    display: block;
    width: 100%;
    padding: 16px;
    border-radius: 18px;
    border: none;
    font-family: 'Nunito', sans-serif;
    font-size: 17px;
    font-weight: 800;
    cursor: pointer;
    transition: transform 0.15s, box-shadow 0.15s;
    margin-bottom: 12px;
  }
  .btn:active { transform: scale(0.97); }

  .btn-yes {
    background: linear-gradient(135deg, var(--pink), var(--purple));
    color: white;
    box-shadow: 0 6px 20px rgba(255,143,171,0.4);
  }
  .btn-yes:hover { box-shadow: 0 8px 28px rgba(255,143,171,0.55); transform: translateY(-2px); }

  .btn-no {
    background: var(--pink-light);
    color: var(--pink);
  }

  .btn-secondary {
    background: var(--purple-light);
    color: var(--purple);
  }

  .btn-green {
    background: linear-gradient(135deg, #74C69D, #52B788);
    color: white;
    box-shadow: 0 6px 20px rgba(116,198,157,0.4);
  }

  /* Persuasion messages */
  .persuade-msg {
    display: none;
    background: linear-gradient(135deg, #FFF0F3, #F0E8FF);
    border-radius: 16px;
    padding: 16px;
    margin-bottom: 20px;
    font-size: 15px;
    font-weight: 700;
    color: var(--text);
    animation: fadeIn 0.4s ease;
  }
  .persuade-msg.show { display: block; }

  /* Date picker */
  /* Calendar */
  .calendar {
    width: 100%;
    margin-bottom: 20px;
  }
  .cal-header {
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 16px;
    gap: 12px;
  }
  .cal-month {
    font-size: 18px;
    font-weight: 900;
    color: var(--text);
  }
  .cal-grid {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 4px;
  }
  .cal-dow {
    text-align: center;
    font-size: 11px;
    font-weight: 800;
    color: #9B7B8A;
    padding: 4px 0 8px;
    text-transform: uppercase;
  }
  .cal-day {
    aspect-ratio: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 12px;
    font-size: 15px;
    font-weight: 700;
    color: #C9B3BC;
    background: transparent;
    cursor: default;
    position: relative;
  }
  .cal-day.empty { background: transparent; }
  .cal-day.disabled { color: #DDD; }
  .cal-day.available {
    color: var(--pink);
    background: var(--pink-light);
    cursor: pointer;
    font-weight: 900;
    transition: all 0.15s;
  }
  .cal-day.available:hover { background: var(--pink); color: white; transform: scale(1.08); }
  .cal-day.available.selected { background: linear-gradient(135deg, var(--pink), var(--purple)); color: white; box-shadow: 0 4px 14px rgba(255,143,171,0.4); transform: scale(1.1); }
  .cal-day.available.selected::after {
    content: '';
    position: absolute;
    inset: -3px;
    border-radius: 14px;
    border: 2px solid var(--pink);
  }
  .cal-sun { color: #FFB3B3; }
  .cal-sat { color: #B3C6FF; }

  /* Food picker */
  .food-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 10px;
    margin-bottom: 24px;
  }

  .food-card {
    border: 2.5px solid var(--pink-light);
    border-radius: 16px;
    padding: 14px 8px;
    cursor: pointer;
    transition: all 0.2s;
    background: white;
    text-align: center;
  }
  .food-card:hover { border-color: var(--pink); background: #FFF5F7; }
  .food-card.selected { border-color: var(--purple); background: var(--purple-light); }

  .food-card .food-emoji { font-size: 30px; display: block; margin-bottom: 4px; }
  .food-card .food-name { font-size: 12px; font-weight: 700; color: var(--text); }

  /* Final screen hearts */
  .hearts {
    font-size: 28px;
    letter-spacing: 4px;
    margin-bottom: 16px;
    animation: heartbeat 1.2s infinite;
  }
  @keyframes heartbeat {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.08); }
  }

  .summary-box {
    background: linear-gradient(135deg, #FFF0F3, #F0E8FF);
    border-radius: 20px;
    padding: 20px;
    margin: 20px 0;
    text-align: left;
  }
  .summary-row {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 8px 0;
    font-size: 15px;
    font-weight: 700;
    border-bottom: 1px solid rgba(255,143,171,0.15);
  }
  .summary-row:last-child { border-bottom: none; }
  .summary-icon { font-size: 22px; width: 30px; text-align: center; }

  .section-label {
    font-size: 13px;
    font-weight: 800;
    color: #9B7B8A;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 14px;
    text-align: left;

  .floating-hearts {
    position: fixed;
    top: 0; left: 0;
    width: 100%; height: 100%;
    pointer-events: none;
    z-index: 0;
    overflow: hidden;
  }
  .fheart {
    position: absolute;
    bottom: -50px;
    font-size: 20px;
    animation: floatUp linear infinite;
    opacity: 0.6;
  }
  @keyframes floatUp {
    0% { transform: translateY(0) rotate(0deg); opacity: 0.6; }
    100% { transform: translateY(-110vh) rotate(360deg); opacity: 0; }
  }
</style>
</head>
<body>

<div class="floating-hearts" id="floatingHearts"></div>

<!-- SCREEN 1: Main invitation -->
<div class="screen active" id="screen1">
  <div class="card">
    <span class="panda" id="mainPanda">🐼</span>
    <h1>Нигора, пойдёшь со мной на свидание?</h1>

    <div class="persuade-msg" id="persuadeMsg"></div>

    <button class="btn btn-yes" onclick="goYes()">💖 Да, конечно!</button>
    <button class="btn btn-no" id="noBtn" onclick="pressNo()">😶 Нет...</button>
  </div>
</div>

<!-- SCREEN 2: Date selection -->
<div class="screen" id="screen2">
  <div class="card">
    <span class="panda" style="animation-delay:0.2s">🗓️</span>
    <h1>Когда тебе удобно?</h1>

    <div class="calendar">
      <div class="cal-header">
        <span class="cal-month">Июль 2026</span>
      </div>
      <div class="cal-grid" id="calGrid"></div>
    </div>

    <button class="btn btn-yes" onclick="goFood()" id="dateNextBtn" disabled style="opacity:0.5">Дальше →</button>
  </div>
</div>

<!-- SCREEN 3: Food selection -->
<div class="screen" id="screen3">
  <div class="card">
    <span class="panda">🍽️</span>
    <h1>Что будем есть?</h1>
    <p class="subtitle">Можно выбрать несколько вариантов</p>

    <p class="section-label">Выбери еду</p>
    <div class="food-grid" id="foodGrid"></div>

    <button class="btn btn-yes" onclick="goFinal()" id="foodNextBtn" disabled style="opacity:0.5">Готово! 🎉</button>
  </div>
</div>

<!-- SCREEN 4: Final -->
<div class="screen" id="screen4">
  <div class="card">
    <div class="hearts">🩷🐼🩷</div>
    <h1>Ура! Это будет лучшее свидание!</h1>
    <p class="subtitle">Я так рад(а)! Ждать уже невозможно 🥹</p>

    <div class="summary-box">
      <div class="summary-row">
        <span class="summary-icon">📅</span>
        <span id="finalDate">—</span>
      </div>
      <div class="summary-row">
        <span class="summary-icon">🍴</span>
        <span id="finalFood">—</span>
      </div>
    </div>

    <p style="font-size:15px; color:#9B7B8A; font-weight:600; margin-bottom: 20px;">Скоро напишу детали! 💌</p>
    <span style="font-size: 48px">🐼🌸</span>
  </div>
</div>

<script>
  // Floating hearts background
  const heartsContainer = document.getElementById('floatingHearts');
  const heartEmojis = ['🩷','💕','✨','🌸','💗','🌷'];
  for (let i = 0; i < 12; i++) {
    const h = document.createElement('div');
    h.className = 'fheart';
    h.textContent = heartEmojis[Math.floor(Math.random() * heartEmojis.length)];
    h.style.left = Math.random() * 100 + '%';
    h.style.animationDuration = (6 + Math.random() * 10) + 's';
    h.style.animationDelay = (Math.random() * 8) + 's';
    h.style.fontSize = (14 + Math.random() * 14) + 'px';
    heartsContainer.appendChild(h);
  }

  // Persuasion messages when pressing "No"
  const noMessages = [
    { panda: '🥺', text: 'Пожалуйста... Я так старался придумать что-нибудь хорошее для тебя 🥺' },
    { panda: '😢', text: 'Окей, я понимаю... Но может всё-таки попробуем? Обещаю — будет классно! 😢' },
    { panda: '😭', text: 'Нигора... Пандочка плачет. Это правда. Смотри сама 😭' },
    { panda: '🙏', text: 'Последний шанс! Я принесу вкусняшки и буду очень-очень стараться! 🙏' },
    { panda: '🐼💔', text: '...Ладно, я подожду. Но кнопка "Да" всё ещё здесь. Она ждёт тебя 💔' },
  ];

  let noCount = 0;
  let selectedDate = null;
  let selectedFoods = [];

  function pressNo() {
    const msg = noMessages[Math.min(noCount, noMessages.length - 1)];
    noCount++;

    // Shake panda
    const panda = document.getElementById('mainPanda');
    panda.textContent = msg.panda.length > 2 ? '😭' : msg.panda;
    panda.classList.remove('sad');
    void panda.offsetWidth;
    panda.classList.add('sad');

    // Show persuasion message
    const el = document.getElementById('persuadeMsg');
    el.textContent = msg.text;
    el.classList.add('show');

    // Change panda emoji
    document.getElementById('mainPanda').textContent = noCount >= 3 ? '😭' : noCount >= 2 ? '😢' : '🥺';
  }

  function goYes() {
    showScreen('screen2');
    buildCalendar();
  }

  function buildCalendar() {
    const grid = document.getElementById('calGrid');
    grid.innerHTML = '';
    const dows = ['Пн','Вт','Ср','Чт','Пт','Сб','Вс'];
    dows.forEach(d => {
      const el = document.createElement('div');
      el.className = 'cal-dow';
      el.textContent = d;
      grid.appendChild(el);
    });
    // July 2026 starts on Wednesday = index 2 in Mon-first grid
    const firstDow = 2;
    const daysInMonth = 31;
    const availableDay = 2;
    for (let i = 0; i < firstDow; i++) {
      const el = document.createElement('div');
      el.className = 'cal-day empty';
      grid.appendChild(el);
    }
    for (let day = 1; day <= daysInMonth; day++) {
      const el = document.createElement('div');
      const dow = (firstDow + day - 1) % 7;
      if (day === availableDay) {
        el.className = 'cal-day available';
        el.onclick = () => selectCalDay(el);
      } else {
        let cls = 'cal-day disabled';
        if (dow === 5) cls += ' cal-sat';
        if (dow === 6) cls += ' cal-sun';
        el.className = cls;
      }
      el.textContent = day;
      grid.appendChild(el);
    }
  }

  function selectCalDay(el) {
    document.querySelectorAll('.cal-day.available').forEach(c => c.classList.remove('selected'));
    el.classList.add('selected');
    selectedDate = '2 июля, чт';
    const btn = document.getElementById('dateNextBtn');
    btn.disabled = false;
    btn.style.opacity = '1';
  }

  function showScreen(id) {
    document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
    document.getElementById(id).classList.add('active');
    window.scrollTo(0, 0);
  }


  // Food options
  const foods = [
    { emoji: '🍣', name: 'Роллы' },
    { emoji: '🍕', name: 'Пицца' },
    { emoji: '🍔', name: 'Бургер' },
    { emoji: '🍜', name: 'Рамэн' },
    { emoji: '🥗', name: 'Салат' },
    { emoji: '🌮', name: 'Тако' },
    { emoji: '🍝', name: 'Паста' },
    { emoji: '🥩', name: 'Стейк' },
    { emoji: '🧆', name: 'Восток' },
  ];

  function goFood() {
    showScreen('screen3');
    buildFood();
  }

  function buildFood() {
    const grid = document.getElementById('foodGrid');
    grid.innerHTML = '';
    foods.forEach(f => {
      const card = document.createElement('div');
      card.className = 'food-card';
      card.innerHTML = `<span class="food-emoji">${f.emoji}</span><span class="food-name">${f.name}</span>`;
      card.onclick = () => toggleFood(card, f.name);
      grid.appendChild(card);
    });
  }

  function toggleFood(card, name) {
    card.classList.toggle('selected');
    if (card.classList.contains('selected')) {
      selectedFoods.push(name);
    } else {
      selectedFoods = selectedFoods.filter(f => f !== name);
    }
    const btn = document.getElementById('foodNextBtn');
    btn.disabled = selectedFoods.length === 0;
    btn.style.opacity = selectedFoods.length === 0 ? '0.5' : '1';
  }

  function goFinal() {
    document.getElementById('finalDate').textContent = selectedDate;
    document.getElementById('finalFood').textContent = selectedFoods.join(', ');
    showScreen('screen4');
  }
</script>
</body>
</html>
